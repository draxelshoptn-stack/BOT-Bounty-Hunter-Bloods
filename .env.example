# ── Required ──────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_bot_token_here

# ── Optional ──────────────────────────────────────────────────────────────────

# Register slash commands instantly to one guild (for testing).
# Remove this to register globally (takes ~1 hour to propagate).
# GUILD_ID=your_server_id_here

# Protect the control panel with a password.
# If set, the dashboard will ask for it on first visit.
# ADMIN_SECRET=choose_a_strong_password_here

# Web server port (default: 3000)
# PORT=3000
